<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">

    <persistence-unit name="parkingPU">

        <!-- KHAI BÁO ENTITY -->
        <class>entity.ParkingLot</class>
        <class>entity.Staff</class>
        <class>entity.Vehicle</class>
        <class>entity.PriceConfig</class>
        <class>entity.Floor</class>
        <class>entity.Slot</class>
        <class>entity.MonthlyTicket</class>
        <class>entity.ParkingRecord</class>

        <properties>
            <!-- KẾT NỐI MYSQL -->
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/quanlynhaxe?useSSL=false&amp;serverTimezone=UTC"/>

            <property name="jakarta.persistence.jdbc.user"
                      value="root"/>

            <property name="jakarta.persistence.jdbc.password"
                      value="Tin@1234"/>

            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver"/>

            <!-- HIBERNATE -->
            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect"/>

            <!-- QUAN TRỌNG -->
            <property name="hibernate.hbm2ddl.auto" value="none"/>

            <!-- DEBUG -->
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>

        </properties>

    </persistence-unit>
</persistence>